<Project Sdk="Microsoft.NET.Sdk">

  <!--
    Composition root and the shipped executable. This is the only project that
    knows about all three others, and the only one allowed to wire them
    together. It targets net8.0-windows because it references the Windows
    platform project; Core and UI stay portable and are what build on macOS.
  -->

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows10.0.17763.0</TargetFramework>
    <SupportedOSPlatformVersion>10.0.17763.0</SupportedOSPlatformVersion>
    <RootNamespace>Dispatch.App</RootNamespace>
    <AssemblyName>Dispatch</AssemblyName>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <!-- Embedded in the .exe: the badge mark shown in Explorer, on pinned and
         desktop shortcuts, and on the taskbar before the window's runtime icon
         loads. Generated from the ArtBadge geometry by tools/Make-AppIcon.ps1. -->
    <ApplicationIcon>app.ico</ApplicationIcon>
    <BuiltInComInteropSupport>true</BuiltInComInteropSupport>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>false</SelfContained>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Dispatch.Core\Dispatch.Core.csproj" />
    <ProjectReference Include="..\Dispatch.UI\Dispatch.UI.csproj" />
    <ProjectReference Include="..\Dispatch.Platform.Windows\Dispatch.Platform.Windows.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Avalonia.Desktop" />
    <PackageReference Include="Microsoft.Extensions.Hosting" />
    <PackageReference Include="Serilog" />
    <PackageReference Include="Serilog.Extensions.Hosting" />
    <PackageReference Include="Serilog.Sinks.File" />
    <PackageReference Include="Velopack" />
  </ItemGroup>

  <ItemGroup Condition="'$(Configuration)' == 'Debug'">
    <PackageReference Include="Avalonia.Diagnostics" />
  </ItemGroup>

  <!--
    The mod pack ships beside the executable. Its archives are large and are
    other authors' work, so they are not committed to the repo (see
    modpack/.gitignore) — they are dropped in locally and mirrored into the
    output here, on both build and publish, so a downloaded release is
    self-contained. Only what the user selects is ever unpacked, so carrying the
    whole pack costs disk in the release but nothing in the game folder.

    SkipUnchangedFiles keeps rebuilds fast; the drop markers and pack metadata
    are excluded so only real archives (and the README) travel.
  -->
  <PropertyGroup>
    <ModPackDir>$(MSBuildProjectDirectory)\..\..\modpack</ModPackDir>
  </PropertyGroup>

  <Target Name="CopyModPackToBuild" AfterTargets="Build">
    <ItemGroup>
      <ModPackFiles Include="$(ModPackDir)\**\*"
                    Exclude="$(ModPackDir)\**\_WHAT-GOES-HERE.txt;$(ModPackDir)\.gitignore" />
    </ItemGroup>
    <Message Importance="high"
             Text="Dispatch: mirroring mod pack to $(OutDir)modpack"
             Condition="'@(ModPackFiles)' != ''" />
    <Copy SourceFiles="@(ModPackFiles)"
          DestinationFiles="@(ModPackFiles->'$(OutDir)modpack\%(RecursiveDir)%(Filename)%(Extension)')"
          SkipUnchangedFiles="true"
          Condition="'@(ModPackFiles)' != ''" />
  </Target>

  <Target Name="CopyModPackToPublish" AfterTargets="Publish">
    <ItemGroup>
      <ModPackFiles Include="$(ModPackDir)\**\*"
                    Exclude="$(ModPackDir)\**\_WHAT-GOES-HERE.txt;$(ModPackDir)\.gitignore" />
    </ItemGroup>
    <Copy SourceFiles="@(ModPackFiles)"
          DestinationFiles="@(ModPackFiles->'$(PublishDir)modpack\%(RecursiveDir)%(Filename)%(Extension)')"
          SkipUnchangedFiles="true"
          Condition="'@(ModPackFiles)' != ''" />
  </Target>

</Project>
