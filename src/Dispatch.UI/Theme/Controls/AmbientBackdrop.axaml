<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:Dispatch.UI.Controls">

  <!--
    Six layers, back to front:

      1  Ink base
      2  three drifting light sources, blue / gold / cyan
      3  the street grid, slowly panning
      4  the coastline the grid stops against
      5  a scan sweep on a long period
      6  vignette, to sit the composition in its frame

    Every loop runs on a different period (23s, 31s, 19s, 41s, 13s) so the
    composition never visibly repeats. Matching periods produce a pulse the eye
    locks onto within a minute.

    On transforms: keyframes animate TranslateTransform.X/Y rather than
    RenderTransform. Avalonia registers animators per transform property and
    has none for RenderTransform itself, so a keyframe targeting it throws at
    the moment the style attaches. Transitions are a different code path and
    handle RenderTransform normally, which is why hover lifts elsewhere in the
    theme are written that way.
  -->

  <ControlTheme x:Key="{x:Type controls:AmbientBackdrop}" TargetType="controls:AmbientBackdrop">
    <Setter Property="IsHitTestVisible" Value="False" />
    <Setter Property="ClipToBounds" Value="True" />
    <Setter Property="IsAnimated" Value="{DynamicResource MotionEnabled}" />

    <Setter Property="Template">
      <ControlTemplate>
        <Panel Background="{DynamicResource Ink}" Opacity="{TemplateBinding Intensity}">

          <!-- ===== Drifting light sources ========================== -->
          <Ellipse Name="OrbBlue"
                   Width="1100" Height="1100"
                   HorizontalAlignment="Left" VerticalAlignment="Top"
                   Margin="-320,-420,0,0"
                   Fill="{DynamicResource OrbBlue}" />

          <Ellipse Name="OrbGold"
                   Width="880" Height="880"
                   HorizontalAlignment="Right" VerticalAlignment="Bottom"
                   Margin="0,0,-260,-300"
                   Fill="{DynamicResource OrbGold}" />

          <Ellipse Name="OrbCyan"
                   Width="760" Height="760"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Fill="{DynamicResource OrbCyan}"
                   Opacity="0.6" />

          <!-- ===== Street grid ===================================== -->
          <Canvas Name="GridLayer"
                  IsVisible="{TemplateBinding ShowGrid}"
                  ClipToBounds="False">
            <Path Data="{StaticResource ArtStreetGrid}"
                  Stroke="{DynamicResource StreetGrid}"
                  StrokeThickness="1"
                  Canvas.Left="-40"
                  Canvas.Top="-20" />
            <Path Data="{StaticResource ArtCoastline}"
                  Stroke="{DynamicResource Blue}"
                  StrokeThickness="1.5"
                  Opacity="0.18"
                  Canvas.Left="-40"
                  Canvas.Top="-20" />
          </Canvas>

          <!-- ===== Scan sweep ====================================== -->
          <Border Name="Scan"
                  Height="1"
                  VerticalAlignment="Top"
                  Background="{DynamicResource ScanLine}"
                  Opacity="0" />

          <!-- ===== Vignette ======================================== -->
          <Border Background="{DynamicResource Vignette}" />

        </Panel>
      </ControlTemplate>
    </Setter>

    <!--
      Animations attach only under IsAnimated=True, so reduced motion leaves a
      still composition rather than a zero-duration infinite loop.
    -->

    <Style Selector="^[IsAnimated=True] /template/ Ellipse#OrbBlue">
      <Style.Animations>
        <Animation Duration="0:0:23" IterationCount="INFINITE" PlaybackDirection="Alternate"
                   Easing="SineEaseInOut">
          <KeyFrame Cue="0%">
            <Setter Property="TranslateTransform.X" Value="0" />
            <Setter Property="TranslateTransform.Y" Value="0" />
          </KeyFrame>
          <KeyFrame Cue="100%">
            <Setter Property="TranslateTransform.X" Value="220" />
            <Setter Property="TranslateTransform.Y" Value="140" />
          </KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>

    <Style Selector="^[IsAnimated=True] /template/ Ellipse#OrbGold">
      <Style.Animations>
        <Animation Duration="0:0:31" IterationCount="INFINITE" PlaybackDirection="Alternate"
                   Easing="SineEaseInOut">
          <KeyFrame Cue="0%">
            <Setter Property="TranslateTransform.X" Value="0" />
            <Setter Property="TranslateTransform.Y" Value="0" />
          </KeyFrame>
          <KeyFrame Cue="100%">
            <Setter Property="TranslateTransform.X" Value="-260" />
            <Setter Property="TranslateTransform.Y" Value="-120" />
          </KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>

    <Style Selector="^[IsAnimated=True] /template/ Ellipse#OrbCyan">
      <Style.Animations>
        <Animation Duration="0:0:19" IterationCount="INFINITE" PlaybackDirection="Alternate"
                   Easing="SineEaseInOut">
          <KeyFrame Cue="0%">
            <Setter Property="TranslateTransform.X" Value="-160" />
            <Setter Property="TranslateTransform.Y" Value="90" />
            <Setter Property="Opacity" Value="0.4" />
          </KeyFrame>
          <KeyFrame Cue="100%">
            <Setter Property="TranslateTransform.X" Value="180" />
            <Setter Property="TranslateTransform.Y" Value="-70" />
            <Setter Property="Opacity" Value="0.8" />
          </KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>

    <!-- The grid pans a single block over 41s: enough to feel alive, not
         enough to notice while reading. -->
    <Style Selector="^[IsAnimated=True] /template/ Canvas#GridLayer">
      <Style.Animations>
        <Animation Duration="0:0:41" IterationCount="INFINITE" PlaybackDirection="Alternate"
                   Easing="SineEaseInOut">
          <KeyFrame Cue="0%">
            <Setter Property="TranslateTransform.X" Value="0" />
            <Setter Property="TranslateTransform.Y" Value="0" />
          </KeyFrame>
          <KeyFrame Cue="100%">
            <Setter Property="TranslateTransform.X" Value="-72" />
            <Setter Property="TranslateTransform.Y" Value="-36" />
          </KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>

    <!-- The sweep: mostly absent, crossing about once every 13 seconds. -->
    <Style Selector="^[IsAnimated=True] /template/ Border#Scan">
      <Style.Animations>
        <Animation Duration="0:0:13" IterationCount="INFINITE" Easing="LinearEasing">
          <KeyFrame Cue="0%">
            <Setter Property="Opacity" Value="0" />
            <Setter Property="TranslateTransform.Y" Value="0" />
          </KeyFrame>
          <KeyFrame Cue="6%">
            <Setter Property="Opacity" Value="0.9" />
          </KeyFrame>
          <KeyFrame Cue="44%">
            <Setter Property="Opacity" Value="0.5" />
          </KeyFrame>
          <KeyFrame Cue="58%">
            <Setter Property="Opacity" Value="0" />
            <Setter Property="TranslateTransform.Y" Value="960" />
          </KeyFrame>
          <KeyFrame Cue="100%">
            <Setter Property="Opacity" Value="0" />
            <Setter Property="TranslateTransform.Y" Value="960" />
          </KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>

  </ControlTheme>

</ResourceDictionary>
