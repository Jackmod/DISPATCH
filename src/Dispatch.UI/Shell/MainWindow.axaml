<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:gallery="clr-namespace:Dispatch.UI.Gallery"
        x:Class="Dispatch.UI.Shell.MainWindow"
        Title="Dispatch"
        Width="1240"
        Height="880"
        MinWidth="1040"
        MinHeight="700"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource Ink}">

  <!--
    Currently hosting the gallery. Replaced by the real navigation chrome and
    routing once the intro and shell land; the gallery then moves behind a
    development-only route rather than being deleted.
  -->

  <gallery:GalleryView />

</Window>
