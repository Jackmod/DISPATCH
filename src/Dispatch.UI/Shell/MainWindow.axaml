<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:gallery="clr-namespace:Dispatch.UI.Gallery"
        xmlns:intro="clr-namespace:Dispatch.UI.Intro"
        x:Class="Dispatch.UI.Shell.MainWindow"
        Title="Dispatch"
        Width="1240"
        Height="880"
        MinWidth="1040"
        MinHeight="700"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource Ink}">

  <!--
    The intro sits over the shell rather than replacing it, so the app is fully
    constructed and laid out behind the animation. By the time the intro fades
    there is nothing left to wait for.
  -->

  <Panel>
    <ContentControl Name="ShellHost" Opacity="0">
      <gallery:GalleryView />
    </ContentControl>

    <intro:IntroView Name="Intro" />
  </Panel>

</Window>
