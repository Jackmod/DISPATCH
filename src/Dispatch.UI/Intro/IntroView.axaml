<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Dispatch.UI.Intro.IntroView"
             Background="{DynamicResource Ink}"
             Focusable="True">

  <!--
    Timed to the launch siren, in four overlapping movements:

      the wordmark draws on, letter by letter, 60ms apart
      the lightbar pulses once: blue, blue, gold, blue, blue
      the finished mark holds under the patrol lights for the body of the siren
      the whole composition lifts 8px and fades into the app as the siren ends

    The letters draw via StrokeDashOffset. Avalonia measures StrokeDashArray
    and StrokeDashOffset in multiples of StrokeThickness, not pixels, so at 3px
    thickness a dash of 120 is 360px â€” comfortably longer than any letter path,
    which is what makes the stroke appear to grow from nothing rather than
    ticking through repeated dashes.

    The gold letter is the A, not the first letter: the accent lands mid-word
    where the eye already is, and it rhymes with the gold segment sitting
    third in the lightbar below.
  -->

  <Panel Name="Root">

    <!-- The field itself carries a very slow drift, so the first frame is
         never completely dead. -->
    <Panel Name="Field" Background="{DynamicResource Ink}" />

    <!--
      Patrol lights washing the field from either side. Red left, blue right,
      alternating on a 380ms cycle with the two sides in opposite phase, which
      is roughly the cadence of a real bar and reads as one immediately.

      Kept to the intro. In the working UI this would be wallpaper inside a
      day; here it is the one moment the product says what it is.
    -->
    <Ellipse Name="PatrolRedLight"
             Width="1000" Height="1000"
             HorizontalAlignment="Left" VerticalAlignment="Center"
             Margin="-380,0,0,0"
             Fill="{DynamicResource PatrolRed}"
             Opacity="0" />

    <Ellipse Name="PatrolBlueLight"
             Width="1000" Height="1000"
             HorizontalAlignment="Right" VerticalAlignment="Center"
             Margin="0,0,-380,0"
             Fill="{DynamicResource PatrolBlue}"
             Opacity="0" />

    <Ellipse Name="Glow"
             Width="900" Height="900"
             HorizontalAlignment="Center" VerticalAlignment="Center"
             Fill="{DynamicResource OrbBlue}"
             Opacity="0" />

    <Panel Name="Composition" VerticalAlignment="Center" HorizontalAlignment="Center">
      <!-- An explicit translate transform for the closing lift to animate. Without
           a concrete TranslateTransform here the transform animator has nothing to
           drive and faults, so the lift is set up rather than left implicit. -->
      <Panel.RenderTransform>
        <TranslateTransform />
      </Panel.RenderTransform>
      <StackPanel Spacing="28" HorizontalAlignment="Center">

        <!-- ===== Wordmark ======================================== -->
        <Canvas Name="Wordmark" Width="352" Height="60" HorizontalAlignment="Center">

          <Path Name="L0" Data="{StaticResource MarkD}" Canvas.Left="0"
                Stroke="{DynamicResource Text}" StrokeThickness="3"
                StrokeLineCap="Round" StrokeJoin="Round"
                StrokeDashArray="120,120" StrokeDashOffset="120" />

          <Path Name="L1" Data="{StaticResource MarkI}" Canvas.Left="44"
                Stroke="{DynamicResource Text}" StrokeThickness="3"
                StrokeLineCap="Round" StrokeJoin="Round"
                StrokeDashArray="120,120" StrokeDashOffset="120" />

          <Path Name="L2" Data="{StaticResource MarkS}" Canvas.Left="88"
                Stroke="{DynamicResource Text}" StrokeThickness="3"
                StrokeLineCap="Round" StrokeJoin="Round"
                StrokeDashArray="120,120" StrokeDashOffset="120" />

          <Path Name="L3" Data="{StaticResource MarkP}" Canvas.Left="132"
                Stroke="{DynamicResource Text}" StrokeThickness="3"
                StrokeLineCap="Round" StrokeJoin="Round"
                StrokeDashArray="120,120" StrokeDashOffset="120" />

          <Path Name="L4" Data="{StaticResource MarkA}" Canvas.Left="176"
                Stroke="{DynamicResource Gold}" StrokeThickness="3"
                StrokeLineCap="Round" StrokeJoin="Round"
                StrokeDashArray="120,120" StrokeDashOffset="120" />

          <Path Name="L5" Data="{StaticResource MarkT}" Canvas.Left="220"
                Stroke="{DynamicResource Text}" StrokeThickness="3"
                StrokeLineCap="Round" StrokeJoin="Round"
                StrokeDashArray="120,120" StrokeDashOffset="120" />

          <Path Name="L6" Data="{StaticResource MarkC}" Canvas.Left="264"
                Stroke="{DynamicResource Text}" StrokeThickness="3"
                StrokeLineCap="Round" StrokeJoin="Round"
                StrokeDashArray="120,120" StrokeDashOffset="120" />

          <Path Name="L7" Data="{StaticResource MarkH}" Canvas.Left="308"
                Stroke="{DynamicResource Text}" StrokeThickness="3"
                StrokeLineCap="Round" StrokeJoin="Round"
                StrokeDashArray="120,120" StrokeDashOffset="120" />

        </Canvas>

        <!-- ===== Lightbar ======================================== -->
        <StackPanel Name="Lightbar" Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
          <Border Name="S0" Width="52" Height="6" CornerRadius="3" Background="{DynamicResource Blue}" Opacity="0.12" />
          <Border Name="S1" Width="52" Height="6" CornerRadius="3" Background="{DynamicResource Blue}" Opacity="0.12" />
          <Border Name="S2" Width="52" Height="6" CornerRadius="3" Background="{DynamicResource Gold}" Opacity="0.12" />
          <Border Name="S3" Width="52" Height="6" CornerRadius="3" Background="{DynamicResource Blue}" Opacity="0.12" />
          <Border Name="S4" Width="52" Height="6" CornerRadius="3" Background="{DynamicResource Blue}" Opacity="0.12" />
        </StackPanel>

      </StackPanel>
    </Panel>

  </Panel>

</UserControl>
