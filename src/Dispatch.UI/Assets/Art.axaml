<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!--
    Scene art. Drawn for this project, from the subject's own geometry.

    Deliberately suggested rather than traced: this is a city that reads as
    Los Santos in its bones — a coastal grid on a slight bias, a freeway
    cutting through it, a downtown block that is denser than the rest — without
    reproducing any real map or any of Rockstar's artwork.
  -->

  <!--
    Street grid, authored on a 1200x800 field. Used at low opacity behind glass
    and as the texture on empty states.

    The bias is the point. A pure orthogonal grid reads as graph paper; three
    degrees off true, with a diagonal arterial and an irregular block or two,
    reads as a city.
  -->
  <StreamGeometry x:Key="ArtStreetGrid">
    M0 96 L1200 60
    M0 208 L1200 172
    M0 320 L1200 284
    M0 432 L1200 396
    M0 544 L1200 508
    M0 656 L1200 620
    M0 768 L1200 732

    M120 0 L156 800
    M264 0 L300 800
    M408 0 L444 800
    M552 0 L588 800
    M696 0 L732 800
    M840 0 L876 800
    M984 0 L1020 800
    M1128 0 L1164 800

    M0 736 L1200 176
    M0 792 L1200 232

    M300 300 L444 296 L448 400 L304 404 Z
    M588 284 L732 280 L736 384 L592 388 Z
    M444 396 L588 392 L592 496 L448 500 Z

    M876 60 L900 640
    M948 48 L972 628
  </StreamGeometry>

  <!--
    Coastline, so the grid has an edge to stop against rather than fading out.
  -->
  <StreamGeometry x:Key="ArtCoastline">
    M0 704 C160 690 260 726 372 742 C500 760 604 726 728 736 C860 746 960 786 1092 776 C1140 772 1176 764 1200 758
  </StreamGeometry>

  <!--
    Badge: the seven-point shield, at illustration scale on a 120x140 field.
    The app mark uses the 20px icon version; this is for hero surfaces.
  -->
  <StreamGeometry x:Key="ArtBadge">
    M60 4 L74 18 L94 14 L100 34 L118 44 L108 62 L118 80 L100 90 L94 110 L74 106 L60 120 L46 106 L26 110 L20 90 L2 80 L12 62 L2 44 L20 34 L26 14 L46 18 Z
    M60 26 L96 40 L96 66 C96 86 81 100 60 108 C39 100 24 86 24 66 L24 40 Z
  </StreamGeometry>

  <!--
    Patrol silhouette: a cruiser in profile with the lightbar on the roof, on a
    240x88 field. Abstract enough to be nobody's vehicle in particular.
  -->
  <StreamGeometry x:Key="ArtCruiser">
    M14 66 L20 46 C22 40 26 36 33 34 L74 26 C82 24 92 24 100 26 L140 34 L196 42 C210 44 222 50 226 58 L228 66
    M14 66 L228 66
    M40 66 A13 13 0 1 1 66 66 A13 13 0 1 1 40 66 Z
    M170 66 A13 13 0 1 1 196 66 A13 13 0 1 1 170 66 Z
    M46 44 L52 32 L86 28 L86 42 Z
    M96 28 L132 32 L146 44 L96 42 Z
    M84 20 L128 20 A4 4 0 0 1 132 24 L132 26 L80 26 L80 24 A4 4 0 0 1 84 20 Z
  </StreamGeometry>

  <!--
    Radio wave: concentric arcs on a 120x120 field, for loading states and the
    voice-control sections.
  -->
  <StreamGeometry x:Key="ArtRadioWave">
    M60 68 A8 8 0 1 1 60 52 A8 8 0 1 1 60 68 Z
    M38 82 A26 26 0 0 1 38 38
    M82 38 A26 26 0 0 1 82 82
    M22 98 A44 44 0 0 1 22 22
    M98 22 A44 44 0 0 1 98 98
    M6 114 A62 62 0 0 1 6 6
    M114 6 A62 62 0 0 1 114 114
  </StreamGeometry>

</ResourceDictionary>
