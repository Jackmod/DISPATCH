<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!--
    The DISPATCH wordmark as eight single-stroke letterforms.

    Drawn as open strokes rather than filled outlines because the intro draws
    them on via StrokeDashOffset, and that only works on a stroked path. Each
    letter lives on its own 34x60 field so it can be placed and delayed
    independently — the letters arrive in sequence, not all at once.

    The forms are condensed and geometric to sit with Archivo Narrow: flat
    terminals, a high waist on the A, and a narrow S that keeps its counters
    open at small sizes.
  -->

  <StreamGeometry x:Key="MarkD">M4 2 V58 M4 2 H18 C28 2 32 12 32 30 C32 48 28 58 18 58 H4</StreamGeometry>
  <StreamGeometry x:Key="MarkI">M17 2 V58</StreamGeometry>
  <StreamGeometry x:Key="MarkS">M30 13 C30 6 24 2 17 2 C9 2 4 7 4 15 C4 30 30 26 30 44 C30 53 24 58 16 58 C9 58 4 54 4 47</StreamGeometry>
  <StreamGeometry x:Key="MarkP">M4 2 V58 M4 2 H19 C27 2 31 8 31 17 C31 26 27 32 19 32 H4</StreamGeometry>
  <StreamGeometry x:Key="MarkA">M2 58 L17 2 L32 58 M8 40 H26</StreamGeometry>
  <StreamGeometry x:Key="MarkT">M2 2 H32 M17 2 V58</StreamGeometry>
  <StreamGeometry x:Key="MarkC">M31 14 C28 6 23 2 17 2 C9 2 3 12 3 30 C3 48 9 58 17 58 C23 58 28 54 31 46</StreamGeometry>
  <StreamGeometry x:Key="MarkH">M4 2 V58 M30 2 V58 M4 30 H30</StreamGeometry>

</ResourceDictionary>
