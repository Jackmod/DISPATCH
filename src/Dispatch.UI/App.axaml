<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Dispatch.UI.App"
             RequestedThemeVariant="Dark">

  <!--
    Dispatch is one considered dark palette rather than a themeable surface, so
    the variant is pinned instead of following the OS.

    Motion.axaml is merged last on purpose: SetReducedMotion swaps that entry
    for MotionReduced.axaml at startup, which is how the reduced-motion setting
    reaches every animation in the application without a single condition being
    checked at an animation site.
  -->

  <Application.Styles>
    <FluentTheme />
    <StyleInclude Source="avares://Dispatch.UI/Theme/Typography.axaml" />
  </Application.Styles>

  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://Dispatch.UI/Theme/Palette.axaml" />
        <ResourceInclude Source="avares://Dispatch.UI/Theme/Spacing.axaml" />
        <ResourceInclude Source="avares://Dispatch.UI/Theme/Motion.axaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Application.Resources>

</Application>
