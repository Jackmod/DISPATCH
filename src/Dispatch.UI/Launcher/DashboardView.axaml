<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:c="clr-namespace:Dispatch.UI.Controls"
             xmlns:vm="clr-namespace:Dispatch.UI.Launcher"
             xmlns:mnt="clr-namespace:Dispatch.Core.Maintenance;assembly=Dispatch.Core"
             x:Class="Dispatch.UI.Launcher.DashboardView"
             x:DataType="vm:DashboardViewModel">

  <Panel>
    <c:AmbientBackdrop Intensity="0.6" />

    <ScrollViewer>
      <StackPanel Margin="40,32,40,32" Spacing="28" MaxWidth="1100" HorizontalAlignment="Left">

        <!-- ===== Hero ========================================== -->
        <Border Height="220"
                CornerRadius="{DynamicResource RadiusCard}"
                ClipToBounds="True"
                BorderBrush="{DynamicResource GlassBorder}"
                BorderThickness="1"
                Classes="reveal">
          <Panel>
            <Panel Background="{DynamicResource NavyDeep}" />
            <Image Source="{Binding Hero}" Stretch="UniformToFill"
                   IsVisible="{Binding HasHero}" />
            <Border>
              <Border.Background>
                <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
                  <GradientStop Offset="0" Color="#E6060A12" />
                  <GradientStop Offset="0.7" Color="#99060A12" />
                  <GradientStop Offset="1" Color="#40060A12" />
                </LinearGradientBrush>
              </Border.Background>
            </Border>

            <Grid ColumnDefinitions="*,Auto" Margin="32,0">
              <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="6">
                <TextBlock Text="ON DUTY" Classes="micro" />
                <TextBlock Text="{Binding OfficerName}" Classes="display" />
                <StackPanel Orientation="Horizontal" Spacing="12">
                  <c:StatusPill Text="{Binding Agency}" Tone="Active" />
                  <TextBlock Text="{Binding Callsign}" Classes="mono gold" VerticalAlignment="Center" />
                </StackPanel>
              </StackPanel>

              <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="8" HorizontalAlignment="Right">
                <Button Classes="primary" Padding="24,14" Name="GoOnDutyButton">
                  <StackPanel Orientation="Horizontal" Spacing="10">
                    <c:Icon Data="{StaticResource IconPlay}" Foreground="{DynamicResource Ink}" />
                    <TextBlock Text="Go on duty" VerticalAlignment="Center" FontSize="15" />
                  </StackPanel>
                </Button>
                <Button Classes="ghost" Content="Safe mode — no plugins"
                        HorizontalAlignment="Right"
                        Command="{Binding LaunchSafeModeCommand}"
                        ToolTip.Tip="Launch with a reminder to turn plugins off, to find out if one is the problem." />
              </StackPanel>
            </Grid>
          </Panel>
        </Border>

        <!-- ===== Pre-flight warning ============================ -->
        <!-- Catch a missing loader, a wiped Script Hook V, or a game update that
             broke it here — with an explanation — rather than at a black screen. -->
        <Border IsVisible="{Binding ShowPreLaunchWarning}"
                Padding="22,18"
                CornerRadius="{DynamicResource RadiusCard}"
                Background="{DynamicResource GlassSurface}"
                BorderBrush="{DynamicResource GlassBorderGold}"
                BorderThickness="1.5">
          <StackPanel Spacing="14">
            <StackPanel Orientation="Horizontal" Spacing="12">
              <c:Icon Data="{StaticResource IconClean}" Foreground="{DynamicResource Gold}" VerticalAlignment="Center" />
              <TextBlock Text="Hold up — this probably won't load" Classes="h2"
                         Foreground="{DynamicResource Gold}" VerticalAlignment="Center" />
            </StackPanel>
            <ItemsControl ItemsSource="{Binding PreLaunchIssues}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="x:String">
                  <Grid ColumnDefinitions="Auto,*" Margin="0,0,0,6">
                    <TextBlock Grid.Column="0" Text="•" Classes="body" Margin="0,0,10,0"
                               Foreground="{DynamicResource Gold}" />
                    <TextBlock Grid.Column="1" Text="{Binding}" Classes="small" TextWrapping="Wrap"
                               Foreground="{DynamicResource TextMuted}" />
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
            <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
              <Button Classes="ghost" Content="Not now" Command="{Binding DismissPreLaunchCommand}" />
              <Button Classes="secondary" Content="Launch anyway" Command="{Binding LaunchAnywayCommand}" />
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- ===== Launch status ================================ -->
        <!-- Go on duty starts RagePluginHook; this says what happened so a launch
             that could not find the loader or the game folder is never silent. -->
        <Border IsVisible="{Binding HasLaunchStatus}"
                Padding="20,14"
                CornerRadius="{DynamicResource RadiusCard}"
                Background="{DynamicResource GlassSurface}"
                BorderBrush="{DynamicResource GlassBorderGold}"
                BorderThickness="1">
          <StackPanel Orientation="Horizontal" Spacing="12">
            <c:Icon Data="{StaticResource IconPlay}" Foreground="{DynamicResource Gold}"
                    VerticalAlignment="Top" />
            <TextBlock Text="{Binding LaunchStatus}" TextWrapping="Wrap" FontSize="13"
                       VerticalAlignment="Center" />
          </StackPanel>
        </Border>

        <!-- ===== Game-update alert ============================= -->
        <!-- The single most common way a working setup dies: Rockstar patched the
             game and Script Hook V no longer matches. Shown only when detected. -->
        <Border IsVisible="{Binding ShowUpdateAlert}"
                Padding="22,18"
                CornerRadius="{DynamicResource RadiusCard}"
                Background="{DynamicResource GlassSurface}"
                BorderBrush="{DynamicResource GlassBorderGold}"
                BorderThickness="1.5">
          <Grid ColumnDefinitions="Auto,*,Auto" >
            <Border Grid.Column="0"
                    Width="40" Height="40" CornerRadius="20"
                    Background="{DynamicResource GoldDim}"
                    VerticalAlignment="Top" Margin="0,0,16,0">
              <c:Icon Data="{StaticResource IconClean}" Foreground="{DynamicResource Gold}"
                      HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <StackPanel Grid.Column="1" Spacing="5" VerticalAlignment="Center">
              <TextBlock Text="{Binding AlertHeadline}" Classes="h2" Foreground="{DynamicResource Gold}" />
              <TextBlock Text="{Binding AlertDetail}" Classes="small muted" TextWrapping="Wrap" MaxWidth="720" />
            </StackPanel>
            <Button Grid.Column="2" Classes="primary" VerticalAlignment="Center"
                    Name="UpdateScriptHookButton" Padding="18,12">
              <TextBlock Text="Fix it" VerticalAlignment="Center" />
            </Button>
          </Grid>
        </Border>

        <!-- ===== Status grid =================================== -->
        <ItemsControl ItemsSource="{Binding Tiles}" Classes="reveal d1">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <WrapPanel />
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:StatusTile">
              <Border Width="252" Height="104" Margin="0,0,16,16"
                      Padding="18,16"
                      CornerRadius="{DynamicResource RadiusCard}"
                      Background="{DynamicResource GlassSurface}"
                      BorderBrush="{DynamicResource GlassBorder}"
                      BorderThickness="1">
                <Grid RowDefinitions="Auto,*,Auto">
                  <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8">
                    <Ellipse Width="7" Height="7" VerticalAlignment="Center"
                             Fill="{Binding Tone, Converter={StaticResource ToneToBrush}}" />
                    <TextBlock Text="{Binding Eyebrow}" Classes="micro" />
                  </StackPanel>
                  <TextBlock Grid.Row="1" Text="{Binding Value}" Classes="h1"
                             VerticalAlignment="Center" />
                  <TextBlock Grid.Row="2" Text="{Binding Detail}" Classes="small"
                             TextTrimming="CharacterEllipsis" />
                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- ===== System health / repair ======================= -->
        <Border Padding="24"
                CornerRadius="{DynamicResource RadiusCard}"
                Background="{DynamicResource GlassSurface}"
                BorderBrush="{DynamicResource GlassBorder}"
                BorderThickness="1">
          <StackPanel Spacing="14">
            <Grid ColumnDefinitions="*,Auto">
              <StackPanel Grid.Column="0" Spacing="3" VerticalAlignment="Center">
                <TextBlock Text="System health" Classes="h1" />
                <TextBlock Classes="small" Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap"
                           Text="Verify every installed file against the record. Catches a Steam/Epic verification or an antivirus deletion that silently wiped your mods." />
              </StackPanel>
              <Button Grid.Column="1" Classes="primary" VerticalAlignment="Center"
                      Command="{Binding RunAuditCommand}"
                      IsEnabled="{Binding !IsAuditing}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <c:Icon Data="{StaticResource IconRefresh}" Size="16" Foreground="{DynamicResource Ink}" />
                  <TextBlock Text="Repair / Verify" VerticalAlignment="Center"
                             IsVisible="{Binding !IsAuditing}" />
                  <TextBlock Text="Checking…" VerticalAlignment="Center"
                             IsVisible="{Binding IsAuditing}" />
                </StackPanel>
              </Button>
            </Grid>

            <ItemsControl ItemsSource="{Binding AuditFindings}" IsVisible="{Binding HasAudit}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="mnt:AuditFinding">
                  <Border Margin="0,0,0,8" Padding="14,12"
                          CornerRadius="{DynamicResource RadiusInput}"
                          Background="{DynamicResource NavyDeep}"
                          BorderBrush="{DynamicResource Steel}" BorderThickness="1">
                    <Grid ColumnDefinitions="Auto,*">
                      <Border Grid.Column="0" Width="4" CornerRadius="2" Margin="0,0,12,0"
                              Background="{Binding Severity, Converter={StaticResource SeverityToBrush}}" />
                      <StackPanel Grid.Column="1" Spacing="3">
                        <TextBlock Text="{Binding Title}" Classes="h2" />
                        <TextBlock Text="{Binding Detail}" Classes="small" Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap" />
                      </StackPanel>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>

        <!-- ===== From your logs =============================== -->
        <Border Padding="24"
                IsVisible="{Binding HasLogFindings}"
                CornerRadius="{DynamicResource RadiusCard}"
                Background="{DynamicResource GlassSurface}"
                BorderBrush="{DynamicResource GlassBorderGold}"
                BorderThickness="1.5">
          <StackPanel Spacing="12">
            <TextBlock Text="From your last session's logs" Classes="h1" />
            <ItemsControl ItemsSource="{Binding LogFindings}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="mnt:LogFinding">
                  <Border Margin="0,0,0,8" Padding="14,12"
                          CornerRadius="{DynamicResource RadiusInput}"
                          Background="{DynamicResource NavyDeep}"
                          BorderBrush="{DynamicResource Steel}" BorderThickness="1">
                    <StackPanel Spacing="3">
                      <TextBlock Text="{Binding Title}" Classes="h2" Foreground="{DynamicResource Gold}" />
                      <TextBlock Text="{Binding Explanation}" Classes="small" Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap" />
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>

      </StackPanel>
    </ScrollViewer>
  </Panel>

</UserControl>
