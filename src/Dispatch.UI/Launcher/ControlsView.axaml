<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:c="clr-namespace:Dispatch.UI.Controls"
             xmlns:vm="clr-namespace:Dispatch.UI.Launcher"
             xmlns:core="clr-namespace:Dispatch.Core.Controls;assembly=Dispatch.Core"
             x:Class="Dispatch.UI.Launcher.ControlsView"
             x:DataType="vm:ControlsViewModel">

  <!--
    The map answers "what is on this key?", the list answers "where is this
    action?", and clicking either filters the other. Edits stage rather than
    write, and the pending bar only appears once there is something to apply.
  -->

  <!-- No AmbientBackdrop here: this view is always hosted inside the Settings hub,
       which draws one already. A second, stacked animated backdrop was pure cost. -->
  <Panel>

    <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="32,24,32,0">

      <!-- ===== Header ========================================== -->
      <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,20">
        <StackPanel Grid.Column="0" Spacing="6">
          <TextBlock Text="CONTROLS" Classes="micro" />
          <TextBlock Text="Keybindings" Classes="display" />
        </StackPanel>

        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
          <c:StatusPill Text="{Binding ConflictSummary}"
                        Tone="Bad"
                        IsVisible="{Binding !IsClean}" />
          <!-- Don't just report a number the user then has to hunt down: one click
               opens the resolver with every conflict and its fixes. -->
          <Button Classes="secondary" Content="Resolve"
                  Command="{Binding ToggleConflictsPanelCommand}"
                  IsVisible="{Binding !IsClean}"
                  ToolTip.Tip="Show every conflict and fix it with one click." />
          <c:StatusPill Text="NO CONFLICTS"
                        Tone="Good"
                        IsVisible="{Binding IsClean}" />
          <Button Classes="ghost" Content="Read from game"
                  Command="{Binding ReadFromGameCommand}"
                  ToolTip.Tip="Read the current values back out of the config files, in case a mod's in-game menu changed them." />
          <Button Classes="ghost" Content="Restore backup"
                  Command="{Binding RestoreBackupCommand}"
                  ToolTip.Tip="Put the config files back to the backup taken before your last apply." />
          <Button Classes="secondary" Content="Export cheat sheet"
                  Command="{Binding ExportCheatSheetCommand}"
                  ToolTip.Tip="Save a printable reference of every bound key." />
          <ComboBox ItemsSource="{Binding PluginFilters}"
                    SelectedItem="{Binding PluginFilter}"
                    Width="180"
                    ToolTip.Tip="Filter the list to one plugin." />
          <!-- ItemsSource of strings, not ComboBoxItem children: SelectedItem
               binds to a string, and item elements never match it. -->
          <ComboBox ItemsSource="{Binding ProfileNames}"
                    SelectedItem="{Binding ProfileName}"
                    Width="160" />
        </StackPanel>
      </Grid>

      <!-- ===== Map ============================================= -->
      <StackPanel Grid.Row="1" Spacing="12" Margin="0,0,0,20">

        <!-- Keyboard and controller are separate namespaces with separate
             conflict sets, so they are separate tabs rather than one mixed list. -->
        <StackPanel Orientation="Horizontal" Spacing="8">
          <RadioButton GroupName="Device" Content="Keyboard" IsChecked="True"
                       Command="{Binding $parent[UserControl].((vm:ControlsViewModel)DataContext).SetDeviceCommand}"
                       CommandParameter="{x:Static core:InputDevice.Keyboard}" />
          <RadioButton GroupName="Device" Content="Controller"
                       Command="{Binding $parent[UserControl].((vm:ControlsViewModel)DataContext).SetDeviceCommand}"
                       CommandParameter="{x:Static core:InputDevice.Controller}" />
        </StackPanel>

        <Grid ColumnDefinitions="Auto,*,Auto" IsVisible="{Binding ShowKeyboardMap}">
          <!-- Layers are essential, not decorative: Left Shift + X and a bare
               X are different bindings and must not share a surface. -->
          <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
            <RadioButton GroupName="Layer" Content="Base" IsChecked="True"
                         Command="{Binding $parent[UserControl].((vm:ControlsViewModel)DataContext).SetLayerCommand}"
                         CommandParameter="{x:Static core:KeyModifier.None}" />
            <RadioButton GroupName="Layer" Content="⇧ Shift"
                         Command="{Binding $parent[UserControl].((vm:ControlsViewModel)DataContext).SetLayerCommand}"
                         CommandParameter="{x:Static core:KeyModifier.Shift}" />
            <RadioButton GroupName="Layer" Content="⌃ Ctrl"
                         Command="{Binding $parent[UserControl].((vm:ControlsViewModel)DataContext).SetLayerCommand}"
                         CommandParameter="{x:Static core:KeyModifier.Control}" />
            <RadioButton GroupName="Layer" Content="⌥ Alt"
                         Command="{Binding $parent[UserControl].((vm:ControlsViewModel)DataContext).SetLayerCommand}"
                         CommandParameter="{x:Static core:KeyModifier.Alt}" />
          </StackPanel>

          <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="16">
            <CheckBox Content="Free keys only" IsChecked="{Binding FreeKeysOnly}" />
            <CheckBox Content="Conflicts only" IsChecked="{Binding ConflictsOnly}" />
          </StackPanel>
        </Grid>

        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                      IsVisible="{Binding ShowKeyboardMap}">
          <c:KeyboardMap Bindings="{Binding AllBindings}"
                         Layer="{Binding Layer}"
                         SelectedKey="{Binding SelectedKey}"
                         FreeKeysOnly="{Binding FreeKeysOnly}"
                         HorizontalAlignment="Left" />
        </ScrollViewer>

        <!-- ===== Controller map ================================= -->
        <StackPanel IsVisible="{Binding !ShowKeyboardMap}" Spacing="10">
          <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
            <RadioButton GroupName="Pad" Content="Xbox" IsChecked="True"
                         Command="{Binding SetPadTypeCommand}" CommandParameter="Xbox" />
            <RadioButton GroupName="Pad" Content="PlayStation"
                         Command="{Binding SetPadTypeCommand}" CommandParameter="PS" />
          </StackPanel>
          <Border Padding="16" CornerRadius="{DynamicResource RadiusCard}"
                  Background="{DynamicResource GlassSurface}" BorderBrush="{DynamicResource GlassBorder}"
                  BorderThickness="1" HorizontalAlignment="Center">
            <c:ControllerMap Bindings="{Binding AllBindings}"
                             SelectedKey="{Binding SelectedKey}"
                             PadType="{Binding PadType}" />
          </Border>
          <TextBlock Classes="small" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center"
                     Text="Click any button to see what's on it and map an action to it." />
        </StackPanel>

        <StackPanel Orientation="Horizontal" Spacing="20" IsVisible="{Binding ShowKeyboardMap}">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Border Width="12" Height="12" CornerRadius="3" Background="{DynamicResource BlueDim}"
                    BorderBrush="{DynamicResource Blue}" BorderThickness="1" VerticalAlignment="Center" />
            <TextBlock Text="Bound" Classes="small" VerticalAlignment="Center" />
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Border Width="12" Height="12" CornerRadius="3" Background="{DynamicResource Red}" VerticalAlignment="Center" />
            <TextBlock Text="Conflict" Classes="small" VerticalAlignment="Center" />
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Border Width="12" Height="12" CornerRadius="3" Background="{DynamicResource GoldDim}"
                    BorderBrush="{DynamicResource Gold}" BorderThickness="1" VerticalAlignment="Center" />
            <TextBlock Text="Reserved — F4 opens the RagePluginHook console" Classes="small" VerticalAlignment="Center" />
          </StackPanel>
        </StackPanel>
      </StackPanel>

      <!-- ===== Action list ===================================== -->
      <Grid Grid.Row="2" RowDefinitions="Auto,*">

        <TextBox Grid.Row="0"
                 Name="SearchBox"
                 Text="{Binding Search}"
                 Watermark="Search actions, plugins, or a key — typing F9 finds what is on F9"
                 Margin="0,0,0,12" />

        <!-- Virtualized: only the rows on screen are realized. -->
        <ListBox Grid.Row="1" ItemsSource="{Binding Rows}"
                 Background="Transparent" BorderThickness="0" Padding="0"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
          <ListBox.Styles>
            <Style Selector="ListBoxItem">
              <Setter Property="Padding" Value="0" />
              <Setter Property="Margin" Value="0" />
              <Setter Property="Background" Value="Transparent" />
            </Style>
            <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
              <Setter Property="Background" Value="Transparent" />
            </Style>
            <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
              <Setter Property="Background" Value="Transparent" />
            </Style>
          </ListBox.Styles>
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="vm:BindingRow">
                <Border Margin="0,0,0,8"
                        Padding="16,12"
                        CornerRadius="{DynamicResource RadiusCard}"
                        Background="{DynamicResource GlassSurface}"
                        BorderBrush="{DynamicResource GlassBorder}"
                        BorderThickness="1">
                  <Grid ColumnDefinitions="*,Auto,Auto">

                    <StackPanel Grid.Column="0" Spacing="3">
                      <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="{Binding Action.Name}" Classes="h2" />
                        <c:StatusPill Text="CHANGED" Tone="Active" IsVisible="{Binding IsChanged}" />
                        <c:StatusPill Text="CONFLICT" Tone="Bad" IsVisible="{Binding IsConflicted}" />
                      </StackPanel>
                      <TextBlock Text="{Binding Action.Description}" Classes="small" TextWrapping="Wrap" />
                      <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="{Binding Action.Plugin}" Classes="micro" />
                        <TextBlock Text="·" Classes="micro" />
                        <TextBlock Text="{Binding Action.ConfigFile}" Classes="mono" />
                      </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4" Margin="16,0">
                      <Border Padding="14,8"
                              MinWidth="150"
                              CornerRadius="{DynamicResource RadiusInput}"
                              Background="{DynamicResource NavyDeep}"
                              BorderBrush="{DynamicResource Steel}"
                              BorderThickness="1">
                        <TextBlock Text="{Binding BindingDisplay}"
                                   Classes="mono"
                                   TextAlignment="Center"
                                   Foreground="{DynamicResource Text}" />
                      </Border>
                      <TextBlock Text="Needs Num Lock on" Classes="micro"
                                 HorizontalAlignment="Center"
                                 Foreground="{DynamicResource Amber}"
                                 IsVisible="{Binding NeedsNumLock}" />
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                      <Button Classes="secondary"
                              Content="Rebind"
                              Command="{Binding $parent[ItemsControl].((vm:ControlsViewModel)DataContext).BeginCaptureCommand}"
                              CommandParameter="{Binding}" />
                      <Button Classes="ghost"
                              Content="Reset"
                              Command="{Binding $parent[ItemsControl].((vm:ControlsViewModel)DataContext).ResetRowCommand}"
                              CommandParameter="{Binding}"
                              ToolTip.Tip="Reset to the recommended, conflict-free key." />
                      <Button Classes="ghost"
                              Content="Clear"
                              Command="{Binding $parent[ItemsControl].((vm:ControlsViewModel)DataContext).UnbindCommand}"
                              CommandParameter="{Binding}" />
                    </StackPanel>

                  </Grid>
                </Border>
              </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Grid>

      <!-- ===== Status + pending bar =========================== -->
      <StackPanel Grid.Row="3" Spacing="8" Margin="0,12,0,16">

        <TextBlock Classes="small"
                   Foreground="{DynamicResource TextMuted}"
                   TextWrapping="Wrap"
                   Text="{Binding StatusMessage}"
                   IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

      <Border IsVisible="{Binding HasPending}"
              Padding="20,14"
              CornerRadius="{DynamicResource RadiusCard}"
              Background="{DynamicResource GoldDim}"
              BorderBrush="{DynamicResource Gold}"
              BorderThickness="1">
        <Grid ColumnDefinitions="Auto,*,Auto,Auto">
          <c:Icon Grid.Column="0" Data="{StaticResource IconInfo}"
                  Foreground="{DynamicResource Gold}" VerticalAlignment="Center" />
          <TextBlock Grid.Column="1"
                     Classes="body"
                     Margin="14,0"
                     VerticalAlignment="Center"
                     Text="{Binding PendingCount, StringFormat='{}{0} change(s) staged. Nothing is written until you apply.'}" />
          <Button Grid.Column="2" Classes="ghost" Content="Discard"
                  Command="{Binding DiscardCommand}" Margin="0,0,10,0" />
          <Button Grid.Column="3" Classes="primary" Content="Review &amp; apply"
                  Command="{Binding PreviewApplyCommand}" />
        </Grid>
      </Border>

      </StackPanel>

    </Grid>

    <!-- ===== Click-a-key mapping panel ====================== -->
    <!-- Clicking a key on the map opens this: what is on the key now, and a
         searchable list of every action you can map onto it. -->
    <Border IsVisible="{Binding IsKeyPanelOpen}"
            HorizontalAlignment="Right"
            Width="388"
            Background="{DynamicResource Navy}"
            BorderBrush="{DynamicResource SteelLight}"
            BorderThickness="1,0,0,0"
            BoxShadow="{DynamicResource ShadowModal}">
      <Grid RowDefinitions="Auto,*">
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Margin="22,20,18,14">
          <Border Grid.Column="0" Width="54" Height="54" CornerRadius="8"
                  Background="{DynamicResource GoldDim}" BorderBrush="{DynamicResource Gold}" BorderThickness="1">
            <TextBlock Text="{Binding SelectedKeyDisplay}" Classes="mono" FontSize="12"
                       Foreground="{DynamicResource GoldBright}"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       TextAlignment="Center" TextWrapping="Wrap" />
          </Border>
          <StackPanel Grid.Column="1" Margin="14,0" VerticalAlignment="Center" Spacing="2">
            <TextBlock Text="EDITING KEY" Classes="micro" />
            <TextBlock Text="{Binding SelectedKeyDisplay}" Classes="h1" TextTrimming="CharacterEllipsis" />
          </StackPanel>
          <Button Grid.Column="2" Classes="ghost" VerticalAlignment="Top" Padding="8"
                  Command="{Binding ClosePanelCommand}" ToolTip.Tip="Close">
            <c:Icon Data="{StaticResource IconClose}" Size="16" />
          </Button>
        </Grid>

        <ScrollViewer Grid.Row="1" Padding="22,0,22,22" VerticalScrollBarVisibility="Auto">
          <StackPanel Spacing="8">

            <TextBlock Text="ON THIS KEY NOW" Classes="micro" />
            <ItemsControl ItemsSource="{Binding ActionsOnSelectedKey}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:BindingRow">
                  <Border Margin="0,0,0,6" Padding="12,10" CornerRadius="{DynamicResource RadiusInput}"
                          Background="{DynamicResource BlueDim}" BorderBrush="{DynamicResource Blue}" BorderThickness="1">
                    <Grid ColumnDefinitions="*,Auto">
                      <StackPanel Grid.Column="0" Spacing="2">
                        <TextBlock Text="{Binding Action.Name}" Classes="h2" />
                        <TextBlock Text="{Binding Action.Plugin}" Classes="micro" />
                      </StackPanel>
                      <Button Grid.Column="1" Classes="ghost" Padding="6" VerticalAlignment="Center"
                              Command="{Binding $parent[ItemsControl].((vm:ControlsViewModel)DataContext).UnbindCommand}"
                              CommandParameter="{Binding}" ToolTip.Tip="Take it off this key">
                        <c:Icon Data="{StaticResource IconClose}" Size="14" />
                      </Button>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
            <TextBlock Text="Nothing on this key yet — pick an action below to put it here."
                       Classes="small" Foreground="{DynamicResource TextFaint}" TextWrapping="Wrap"
                       IsVisible="{Binding !SelectedKeyHasActions}" />

            <TextBlock Text="MAP AN ACTION TO THIS KEY" Classes="micro" Margin="0,14,0,0" />
            <TextBox Text="{Binding KeyPanelSearch}"
                     Watermark="Search actions across every plugin…" />
            <ItemsControl ItemsSource="{Binding AssignableActions}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:BindingRow">
                  <Button Classes="ghost" HorizontalAlignment="Stretch"
                          HorizontalContentAlignment="Stretch"
                          Margin="0,0,0,5" Padding="12,10"
                          Command="{Binding $parent[ItemsControl].((vm:ControlsViewModel)DataContext).MapToKeyCommand}"
                          CommandParameter="{Binding}">
                    <Grid ColumnDefinitions="*,Auto">
                      <StackPanel Grid.Column="0" Spacing="2">
                        <TextBlock Text="{Binding Action.Name}" Classes="h2" />
                        <TextBlock Text="{Binding Action.Plugin}" Classes="micro" />
                      </StackPanel>
                      <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="1">
                        <TextBlock Text="{Binding BindingDisplay}" Classes="mono" FontSize="11"
                                   Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Right" />
                        <TextBlock Text="Map here →" Classes="micro"
                                   Foreground="{DynamicResource Gold}" HorizontalAlignment="Right" />
                      </StackPanel>
                    </Grid>
                  </Button>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

          </StackPanel>
        </ScrollViewer>
      </Grid>
    </Border>

    <!-- ===== Conflict resolver ============================== -->
    <!-- Every contested key, each with the fixes that clear it: swap the two,
         or move one to a free key. Flagging a conflict is not enough — this is
         where it gets resolved. -->
    <Border IsVisible="{Binding ShowConflictsPanel}" Background="{DynamicResource Scrim}">
      <Border VerticalAlignment="Center" HorizontalAlignment="Center"
              Width="620" MaxHeight="560"
              CornerRadius="{DynamicResource RadiusModal}"
              Background="{DynamicResource Navy}"
              BorderBrush="{DynamicResource SteelLight}"
              BorderThickness="1"
              BoxShadow="{DynamicResource ShadowModal}">
        <Grid RowDefinitions="Auto,*,Auto" Margin="28,24,28,20">
          <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,16">
            <TextBlock Text="RESOLVE CONFLICTS" Classes="micro" />
            <TextBlock Text="{Binding ConflictSummary}" Classes="h1" />
            <TextBlock Classes="small" Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap"
                       Text="Two actions can't share one key. Swap them, or move one to a free key we pick for you." />
          </StackPanel>

          <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Conflicts}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="core:Conflict">
                  <Border Margin="0,0,0,10" Padding="16,12"
                          CornerRadius="{DynamicResource RadiusCard}"
                          Background="{DynamicResource NavyDeep}"
                          BorderBrush="{DynamicResource Red}" BorderThickness="1">
                    <StackPanel Spacing="10">
                      <StackPanel Orientation="Horizontal" Spacing="10">
                        <Border Padding="10,5" CornerRadius="{DynamicResource RadiusInput}"
                                Background="{DynamicResource NavyDeep}"
                                BorderBrush="{DynamicResource Red}" BorderThickness="1">
                          <TextBlock Text="{Binding Binding.Display}" Classes="mono"
                                     Foreground="{DynamicResource Red}" />
                        </Border>
                        <TextBlock Text="is claimed by:" Classes="small" VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextMuted}" />
                      </StackPanel>
                      <ItemsControl ItemsSource="{Binding Actions}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate x:DataType="core:GameAction">
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,1">
                              <TextBlock Text="{Binding Name}" Classes="body" />
                              <TextBlock Text="{Binding Plugin}" Classes="micro" VerticalAlignment="Center" />
                            </StackPanel>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                      <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Classes="secondary" Content="Swap"
                                IsVisible="{Binding CanSwap}"
                                Command="{Binding $parent[ItemsControl].((vm:ControlsViewModel)DataContext).ResolveBySwapCommand}"
                                CommandParameter="{Binding}"
                                ToolTip.Tip="Exchange these two actions' keys." />
                        <Button Classes="primary" Content="Move to a free key"
                                Command="{Binding $parent[ItemsControl].((vm:ControlsViewModel)DataContext).ResolveByReassignCommand}"
                                CommandParameter="{Binding}"
                                ToolTip.Tip="Keep the first, move the rest to keys nothing else uses." />
                      </StackPanel>
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>

          <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,16,0,0">
            <TextBlock Text="These are staged like any edit — review and apply when you're done."
                       Classes="small" Foreground="{DynamicResource TextFaint}"
                       VerticalAlignment="Center" Margin="0,0,8,0" TextWrapping="Wrap" MaxWidth="300" />
            <Button Classes="primary" Content="Done" Command="{Binding CloseConflictsPanelCommand}" />
          </StackPanel>
        </Grid>
      </Border>
    </Border>

    <!-- ===== Apply preview ================================== -->
    <!-- Apply shows the diff first: exactly which line in which file moves from
         what to what, before a single byte is written. -->
    <Border IsVisible="{Binding ShowApplyPreview}" Background="{DynamicResource Scrim}">
      <Border VerticalAlignment="Center" HorizontalAlignment="Center"
              Width="640" MaxHeight="560"
              CornerRadius="{DynamicResource RadiusModal}"
              Background="{DynamicResource Navy}"
              BorderBrush="{DynamicResource Gold}"
              BorderThickness="1"
              BoxShadow="{DynamicResource ShadowModal}">
        <Grid RowDefinitions="Auto,*,Auto" Margin="28,24,28,20">
          <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,16">
            <TextBlock Text="REVIEW CHANGES" Classes="micro" />
            <TextBlock Text="{Binding PendingCount, StringFormat='{}{0} change(s) will be written'}" Classes="h1" />
            <TextBlock Classes="small" Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap"
                       Text="Only these lines change. Every file is backed up first, so you can restore it." />
          </StackPanel>

          <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Border Padding="16,12" CornerRadius="{DynamicResource RadiusCard}"
                    Background="{DynamicResource NavyDeep}"
                    BorderBrush="{DynamicResource Steel}" BorderThickness="1">
              <ItemsControl ItemsSource="{Binding PendingDiff}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="x:String">
                    <TextBlock Text="{Binding}" Classes="mono" FontSize="12" TextWrapping="Wrap"
                               Margin="0,0,0,6" />
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </Border>
          </ScrollViewer>

          <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,16,0,0">
            <Button Classes="ghost" Content="Cancel" Command="{Binding CancelApplyPreviewCommand}" />
            <Button Classes="primary" Content="Write changes" Command="{Binding ApplyCommand}" />
          </StackPanel>
        </Grid>
      </Border>
    </Border>

    <!-- ===== Capture overlay ================================== -->
    <Border IsVisible="{Binding Capturing, Converter={x:Static ObjectConverters.IsNotNull}}"
            Background="{DynamicResource Scrim}">
      <Border VerticalAlignment="Center" HorizontalAlignment="Center"
              Padding="48,40"
              CornerRadius="{DynamicResource RadiusModal}"
              Background="{DynamicResource Navy}"
              BorderBrush="{DynamicResource Gold}"
              BorderThickness="2"
              BoxShadow="{DynamicResource ShadowModal}">
        <StackPanel Spacing="16" HorizontalAlignment="Center">
          <TextBlock Text="PRESS A KEY" Classes="micro" HorizontalAlignment="Center" />
          <TextBlock Text="{Binding Capturing.Action.Name}" Classes="h1" HorizontalAlignment="Center" />
          <TextBlock Classes="small" HorizontalAlignment="Center"
                     Text="Hold Shift, Ctrl or Alt to bind a chord.  Esc cancels.  Delete unbinds." />
        </StackPanel>
      </Border>
    </Border>

  </Panel>

</UserControl>
