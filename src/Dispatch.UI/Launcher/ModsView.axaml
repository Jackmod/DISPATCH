<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:c="clr-namespace:Dispatch.UI.Controls"
             xmlns:vm="clr-namespace:Dispatch.UI.Launcher"
             x:Class="Dispatch.UI.Launcher.ModsView"
             x:DataType="vm:ModsViewModel">

  <!--
    Empty state that teaches, over the street-grid texture, as the spec asks.
    The real grid arrives with the catalogue and the mod detail panel; this is
    what the section looks like before an install has happened.
  -->

  <Panel>
    <c:AmbientBackdrop Intensity="0.5" ShowGrid="True" />

    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="20" MaxWidth="440">
      <Viewbox Width="72" HorizontalAlignment="Center" Opacity="0.7">
        <Canvas Width="20" Height="20">
          <Path Data="{StaticResource IconMods}"
                Stroke="{DynamicResource Blue}" StrokeThickness="1"
                StrokeLineCap="Round" StrokeJoin="Round" />
        </Canvas>
      </Viewbox>
      <TextBlock Text="No mods installed yet" Classes="h1" HorizontalAlignment="Center" />
      <TextBlock Classes="body muted" TextAlignment="Center" TextWrapping="Wrap"
                 Text="Once you have run the installer, every mod appears here as a card — its version, the keys it owns, and buttons to reconfigure, repair, update or remove it." />
      <Button Classes="secondary" HorizontalAlignment="Center">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <c:Icon Data="{StaticResource IconPlus}" Size="16" />
          <TextBlock Text="Add a mod" VerticalAlignment="Center" />
        </StackPanel>
      </Button>
    </StackPanel>
  </Panel>

</UserControl>
