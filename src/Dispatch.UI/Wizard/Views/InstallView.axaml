<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:c="clr-namespace:Dispatch.UI.Controls"
             xmlns:steps="clr-namespace:Dispatch.UI.Wizard.Steps"
             x:Class="Dispatch.UI.Wizard.Views.InstallView"
             x:DataType="steps:InstallStep">

  <!--
    A loading screen in the style the genre established: full-bleed stills
    crossfading behind the readout, with a tip along the bottom.

    The stills come from Assets/Loading and are compiled into the executable,
    so a downloaded release has them. When that folder is empty — which it is
    in the repository, because no game or mod artwork is bundled — the vector
    scene takes over and the screen is complete either way.

    The readout stays quiet regardless: current phase only, one detail line, a
    counter. The log is collapsed by default and always will be; a wall of
    scrolling text makes an install feel fragile.
  -->

  <Panel>

    <!-- ===== Backdrop ========================================== -->
    <c:LoadingSlideshow Name="Slideshow" Interval="0:0:9" />

    <!-- Fallback for a build with no stills present. -->
    <Panel IsVisible="{Binding !#Slideshow.HasImages}">
      <Panel Background="{DynamicResource NavyDeep}" />
      <Viewbox Stretch="UniformToFill" Opacity="0.30">
        <Canvas Width="1200" Height="800">
          <Path Data="{StaticResource ArtStreetGrid}"
                Stroke="{DynamicResource StreetGrid}"
                StrokeThickness="1.6" />
        </Canvas>
      </Viewbox>
      <Ellipse Width="620" Height="620"
               HorizontalAlignment="Left" VerticalAlignment="Bottom"
               Margin="-200,0,0,-260"
               Fill="{DynamicResource PatrolRed}"
               Opacity="0.5" />
      <Ellipse Width="620" Height="620"
               HorizontalAlignment="Right" VerticalAlignment="Top"
               Margin="0,-260,-200,0"
               Fill="{DynamicResource PatrolBlue}"
               Opacity="0.5" />
      <Viewbox Width="520" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.5">
        <Canvas Width="240" Height="88">
          <Path Data="{StaticResource ArtCruiser}"
                Stroke="{DynamicResource BlueBright}"
                StrokeThickness="2"
                StrokeLineCap="Round"
                StrokeJoin="Round" />
        </Canvas>
      </Viewbox>
      <Border Background="{DynamicResource Vignette}" />
    </Panel>

    <!-- ===== Readout ========================================== -->
    <Grid RowDefinitions="*,Auto" Margin="64,40,64,32">

      <!-- Width rather than MaxWidth: a left-aligned StackPanel shrinks to its
           content, which stunts the progress rail and collapses the spacer
           column so the counter collides with the note beside it. -->
      <StackPanel Grid.Row="0" VerticalAlignment="Bottom" Spacing="28" Width="880" HorizontalAlignment="Left">

        <StackPanel Spacing="10">
          <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
            <TextBlock Text="INSTALLING" Classes="micro" VerticalAlignment="Center" />
            <!-- What we're installing onto, front and centre so Legacy is never in doubt. -->
            <Border Padding="9,4" CornerRadius="6"
                    Background="{DynamicResource GreenWash}"
                    BorderBrush="{DynamicResource Green}" BorderThickness="1">
              <TextBlock Text="{Binding VersionReadout}" Classes="micro" Foreground="{DynamicResource Green}" />
            </Border>
          </StackPanel>
          <TextBlock Text="{Binding Phase}" Classes="display" />
          <TextBlock Text="{Binding Detail}" Classes="mono" />
        </StackPanel>

        <StackPanel Spacing="14">
          <!-- The bar carries overall progress; the rail below still says
               which of the seven phases that progress is inside. -->
          <c:ProgressBarSolid Fraction="{Binding Fraction}" BarHeight="12" />

          <c:LightbarProgress SegmentCount="7"
                              CompletedSegments="{Binding PhaseIndex}"
                              SegmentHeight="4" />

          <Grid ColumnDefinitions="Auto,Auto,*,Auto">
            <TextBlock Grid.Column="0" Text="{Binding Counter}" Classes="mono" />

            <!-- Elapsed and estimated-remaining, so the run never feels stalled. -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" Margin="24,0,0,0" VerticalAlignment="Center">
              <c:Icon Data="{StaticResource IconClock}" Size="14" Foreground="{DynamicResource TextMuted}"
                      VerticalAlignment="Center" />
              <TextBlock Text="{Binding ElapsedText}" Classes="mono" VerticalAlignment="Center" />
              <TextBlock Text="·" Classes="mono muted" VerticalAlignment="Center" />
              <TextBlock Text="{Binding RemainingText}" Classes="mono muted" VerticalAlignment="Center" />
            </StackPanel>

            <TextBlock Grid.Column="3"
                       Classes="small"
                       Text="Nothing blocks. A failed mod is reported at the end." />
          </Grid>
        </StackPanel>

        <Expander IsExpanded="{Binding IsLogExpanded}" Header="Show detailed log" HorizontalAlignment="Left">
          <ScrollViewer Name="LogScroll" Height="180" Width="820" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Log}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="x:String">
                  <TextBlock Text="{Binding}" Classes="mono" TextWrapping="NoWrap" />
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Expander>

      </StackPanel>

      <c:TipRail Grid.Row="1" Interval="0:0:8" Margin="0,28,0,0" />

    </Grid>

    <!-- ===== Game-running block ============================== -->
    <!-- Held here rather than writing into files the game has locked. -->
    <Border IsVisible="{Binding BlockedByGame}" Background="{DynamicResource Scrim}">
      <Border MaxWidth="520" VerticalAlignment="Center" HorizontalAlignment="Center"
              Padding="32,28"
              CornerRadius="{DynamicResource RadiusCard}"
              Background="{DynamicResource Navy}"
              BorderBrush="{DynamicResource GlassBorderGold}"
              BorderThickness="1.5">
        <StackPanel Spacing="16">
          <TextBlock Text="Close the game first" Classes="h1" Foreground="{DynamicResource Gold}" />
          <TextBlock Classes="body muted" TextWrapping="Wrap"
                     Text="{Binding BlockingProcess, StringFormat='{}{0} is running. Installing while it is open would write into files it has locked and leave a half-finished install. Close it completely, then continue.'}" />
          <Button Classes="primary" Content="I've closed it — continue"
                  HorizontalAlignment="Left" Name="RetryGameButton" />
        </StackPanel>
      </Border>
    </Border>

  </Panel>

</UserControl>
