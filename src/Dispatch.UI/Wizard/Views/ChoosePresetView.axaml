<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:c="clr-namespace:Dispatch.UI.Controls"
             xmlns:steps="clr-namespace:Dispatch.UI.Wizard.Steps"
             x:Class="Dispatch.UI.Wizard.Views.ChoosePresetView"
             x:DataType="steps:ChoosePresetStep">

  <!--
    Three live preview surfaces, not radio buttons with captions.

    Each card carries its own scene, and the scene escalates with the tier: one
    quiet unit for Standard, a second unit plus patrol lighting for Full Duty,
    air support on top for Realism. The cards therefore say what they mean
    before a word is read.

    If a user has dropped an image into the backgrounds folder for a tier, it
    is used instead of that tier's vector scene. Nothing is bundled — the app
    ships with the vector art and picks up overrides at runtime.
  -->

  <UserControl.Styles>
    <Style Selector="ListBox.presets">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0" />
    </Style>

    <Style Selector="ListBox.presets ListBoxItem">
      <Setter Property="Padding" Value="0" />
      <Setter Property="Margin" Value="0,0,20,0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="CornerRadius" Value="{DynamicResource RadiusCard}" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Transitions">
        <Transitions>
          <TransformOperationsTransition Property="RenderTransform"
                                         Duration="{DynamicResource StandardDuration}"
                                         Easing="{DynamicResource StandardEasing}" />
        </Transitions>
      </Setter>
    </Style>

    <Style Selector="ListBox.presets ListBoxItem:pointerover">
      <Setter Property="RenderTransform" Value="translateY(-4px)" />
    </Style>

    <Style Selector="ListBox.presets ListBoxItem /template/ ContentPresenter">
      <Setter Property="Background" Value="Transparent" />
    </Style>

    <!-- The chosen card lights up green and holds a steady green edge, so the
         selection reads at a glance rather than as a faint gold hairline. -->
    <Style Selector="ListBox.presets ListBoxItem:selected Border#Frame">
      <Setter Property="BorderBrush" Value="{DynamicResource Green}" />
      <Setter Property="BorderThickness" Value="2" />
    </Style>

    <!-- The pulsing green halo. Off by default; the chosen card breathes it
         so the selection is unmistakable. -->
    <Style Selector="ListBox.presets ListBoxItem Border#SelectionGlow">
      <Setter Property="Opacity" Value="0" />
    </Style>
    <Style Selector="ListBox.presets ListBoxItem:selected Border#SelectionGlow">
      <Setter Property="Opacity" Value="1" />
      <Style.Animations>
        <Animation Duration="0:0:1.6" IterationCount="INFINITE" Easing="SineEaseInOut">
          <KeyFrame Cue="0%">
            <Setter Property="Opacity" Value="0.4" />
          </KeyFrame>
          <KeyFrame Cue="50%">
            <Setter Property="Opacity" Value="1" />
          </KeyFrame>
          <KeyFrame Cue="100%">
            <Setter Property="Opacity" Value="0.4" />
          </KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>
  </UserControl.Styles>

  <Grid RowDefinitions="Auto,*,Auto" Margin="48,32,48,32">

    <StackPanel Grid.Row="0" Spacing="6" Margin="0,0,0,20" Classes="reveal">
      <TextBlock Text="STEP 4" Classes="micro" />
      <TextBlock Text="Choose a setup" Classes="display" />
    </StackPanel>

    <!--
      The customise overlay. It sits above the whole screen so the mod checklist
      has room, and only the ticked mods are ever unpacked into the game. Opened
      from the Customize button in the summary bar; closed by Done.
    -->
    <Border Grid.Row="0" Grid.RowSpan="3"
            ZIndex="10"
            IsVisible="{Binding IsCustomizing}"
            Background="{DynamicResource Scrim}">
      <Border Margin="60,24"
              MaxWidth="720"
              HorizontalAlignment="Center"
              CornerRadius="{DynamicResource RadiusCard}"
              Background="{DynamicResource Navy}"
              BorderBrush="{DynamicResource GlassBorder}"
              BorderThickness="1"
              BoxShadow="{DynamicResource ShadowRaised}">
        <Grid RowDefinitions="Auto,*,Auto" Margin="28,24">

          <StackPanel Grid.Row="0" Spacing="10" Margin="0,0,0,16">
            <TextBlock Text="Customise your install" Classes="h1" />
            <TextBlock Classes="small muted"
                       Text="Untick anything you don't want. Only ticked mods are unpacked into your game — nothing else is touched." />
            <TextBox Text="{Binding ModSearch}"
                     Watermark="Search mods…"
                     Margin="0,4,0,0" />
          </StackPanel>

          <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding VisibleMods}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="steps:ModPick">
                  <Border Padding="14,10" Margin="0,0,0,6"
                          CornerRadius="{DynamicResource RadiusInput}"
                          Background="{DynamicResource GlassSurface}">
                    <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                      <CheckBox Grid.Column="0"
                                IsChecked="{Binding IsSelected}"
                                IsEnabled="{Binding CanToggle}"
                                VerticalAlignment="Center"
                                Margin="0,0,12,0" />
                      <StackPanel Grid.Column="1" Spacing="1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Name}" Classes="body" />
                        <TextBlock Text="{Binding Author}" Classes="small muted" />
                      </StackPanel>

                      <!-- Required badge, only on core dependencies. -->
                      <Border Grid.Column="2"
                              VerticalAlignment="Center"
                              Margin="0,0,8,0"
                              Padding="8,3"
                              CornerRadius="6"
                              IsVisible="{Binding IsRequired}"
                              Background="{DynamicResource GlassSurface}"
                              BorderBrush="{DynamicResource GlassBorderGold}"
                              BorderThickness="1">
                        <TextBlock Text="REQUIRED" Classes="micro" Foreground="{DynamicResource Gold}" />
                      </Border>

                      <Border Grid.Column="3"
                              VerticalAlignment="Center"
                              Padding="8,3"
                              CornerRadius="6"
                              Background="{DynamicResource GlassSurface}"
                              BorderBrush="{DynamicResource GlassBorder}"
                              BorderThickness="1">
                        <TextBlock Text="{Binding SourceLabel}" Classes="micro" />
                      </Border>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>

          <Grid Grid.Row="2" ColumnDefinitions="*,Auto" Margin="0,16,0,0">
            <TextBlock Grid.Column="0"
                       Text="{Binding SelectionSummary}"
                       Classes="small muted"
                       VerticalAlignment="Center" />
            <Button Grid.Column="1"
                    Classes="primary"
                    Content="Done"
                    Click="OnToggleCustomize" />
          </Grid>
        </Grid>
      </Border>
    </Border>

    <ListBox Grid.Row="1"
             Classes="presets"
             ItemsSource="{Binding Presets}"
             SelectedItem="{Binding Selected}"
             ScrollViewer.VerticalScrollBarVisibility="Disabled"
             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
      <ListBox.ItemsPanel>
        <ItemsPanelTemplate>
          <UniformGrid Rows="1" />
        </ItemsPanelTemplate>
      </ListBox.ItemsPanel>

      <ListBox.ItemTemplate>
        <DataTemplate DataType="steps:PresetOption">

         <Panel>

          <!-- The pulsing green halo, behind the card and non-interactive. -->
          <Border Name="SelectionGlow"
                  CornerRadius="{DynamicResource RadiusCard}"
                  Background="{DynamicResource GreenWash}"
                  BoxShadow="{DynamicResource GlowGreen}"
                  IsHitTestVisible="False" />

          <Border Name="Frame"
                  CornerRadius="{DynamicResource RadiusCard}"
                  Background="{DynamicResource GlassSurface}"
                  BorderBrush="{DynamicResource GlassBorder}"
                  BorderThickness="1"
                  BoxShadow="{DynamicResource ShadowRaised}"
                  ClipToBounds="True">

            <Grid RowDefinitions="200,*">

              <!-- ===== Scene ==================================== -->
              <Panel Grid.Row="0" ClipToBounds="True">

                <Panel Background="{DynamicResource NavyDeep}" />

                <!-- A user-supplied image wins over the vector scene. -->
                <Image Source="{Binding Background}"
                       Stretch="UniformToFill"
                       IsVisible="{Binding Background, Converter={x:Static ObjectConverters.IsNotNull}}" />

                <!-- Vector scene, shown when no image has been supplied. -->
                <Panel IsVisible="{Binding Background, Converter={x:Static ObjectConverters.IsNull}}">

                  <Viewbox Stretch="UniformToFill" Opacity="0.45">
                    <Canvas Width="1200" Height="800">
                      <Path Data="{StaticResource ArtStreetGrid}"
                            Stroke="{DynamicResource StreetGrid}"
                            StrokeThickness="1.6" />
                    </Canvas>
                  </Viewbox>

                  <!-- Patrol lighting from the second tier up. -->
                  <Ellipse Width="380" Height="380"
                           HorizontalAlignment="Left" VerticalAlignment="Center"
                           Margin="-150,0,0,0"
                           Fill="{DynamicResource PatrolRed}"
                           Opacity="0.75"
                           IsVisible="{Binding ShowPatrolLighting}" />
                  <Ellipse Width="380" Height="380"
                           HorizontalAlignment="Right" VerticalAlignment="Center"
                           Margin="0,0,-150,0"
                           Fill="{DynamicResource PatrolBlue}"
                           Opacity="0.75"
                           IsVisible="{Binding ShowPatrolLighting}" />

                  <!-- Air support, top tier only. -->
                  <Viewbox Width="120"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Top"
                           Margin="0,18,24,0"
                           IsVisible="{Binding ShowAirUnit}">
                    <Canvas Width="120" Height="120">
                      <Path Data="{StaticResource ArtRadioWave}"
                            Stroke="{DynamicResource GoldBright}"
                            StrokeThickness="3"
                            StrokeLineCap="Round"
                            Opacity="0.7" />
                    </Canvas>
                  </Viewbox>

                  <!-- Second unit, from the second tier up, set behind. -->
                  <Viewbox Width="150"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Bottom"
                           Margin="16,0,0,58"
                           Opacity="0.4"
                           IsVisible="{Binding ShowSecondUnit}">
                    <Canvas Width="240" Height="88">
                      <Path Data="{StaticResource ArtCruiser}"
                            Stroke="{DynamicResource BlueBright}"
                            StrokeThickness="2.5"
                            StrokeLineCap="Round"
                            StrokeJoin="Round" />
                    </Canvas>
                  </Viewbox>

                  <!-- The lead unit, every tier. -->
                  <Viewbox Width="230"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Bottom"
                           Margin="0,0,0,20">
                    <Canvas Width="240" Height="88">
                      <Path Data="{StaticResource ArtCruiser}"
                            Stroke="{DynamicResource BlueBright}"
                            StrokeThickness="2"
                            StrokeLineCap="Round"
                            StrokeJoin="Round" />
                    </Canvas>
                  </Viewbox>

                </Panel>

                <Border Background="{DynamicResource Vignette}" />

                <c:StatusPill Text="{Binding Tagline}"
                              Tone="Active"
                              HorizontalAlignment="Left"
                              VerticalAlignment="Top"
                              Margin="16"
                              IsVisible="{Binding Tagline, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

              </Panel>

              <!-- ===== Copy ==================================== -->
              <StackPanel Grid.Row="1" Spacing="12" Margin="20">

                <TextBlock Text="{Binding Name}" Classes="h1" />

                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock Text="{Binding Counts}" Classes="mono" />
                  <TextBlock Text="·" Classes="mono" />
                  <TextBlock Text="{Binding Duration}" Classes="mono" />
                </StackPanel>

                <TextBlock Text="{Binding Summary}"
                           Classes="body muted"
                           TextWrapping="Wrap" />

                <ItemsControl ItemsSource="{Binding Features}" Margin="0,4,0,0">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="x:String">
                      <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,0,0,8">
                        <Border Width="5" Height="5" CornerRadius="2.5"
                                Background="{DynamicResource Gold}"
                                VerticalAlignment="Center" />
                        <TextBlock Text="{Binding}" Classes="small" VerticalAlignment="Center" />
                      </StackPanel>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>

                <c:StatusPill Text="COMING SOON"
                              Tone="Neutral"
                              IsVisible="{Binding ComingSoon}" />

              </StackPanel>
            </Grid>
          </Border>

         </Panel>

        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>

    <!-- ===== Size summary ==================================== -->
    <Border Grid.Row="2"
            Margin="0,20,0,0"
            Padding="20,14"
            CornerRadius="{DynamicResource RadiusCard}"
            Background="{DynamicResource GlassSurface}"
            BorderBrush="{DynamicResource GlassBorder}"
            BorderThickness="1">
      <Grid ColumnDefinitions="Auto,Auto,Auto,*,Auto">

        <StackPanel Grid.Column="0" Spacing="2" Margin="0,0,40,0">
          <TextBlock Text="SELECTED" Classes="micro" />
          <TextBlock Text="{Binding SelectionSummary}" Classes="mono" />
        </StackPanel>

        <StackPanel Grid.Column="1" Spacing="2" Margin="0,0,40,0">
          <TextBlock Text="DISK NEEDED" Classes="micro" />
          <TextBlock Text="{Binding DiskRequired}" Classes="mono" />
        </StackPanel>

        <StackPanel Grid.Column="2" Spacing="2">
          <TextBlock Text="FREE SPACE" Classes="micro" />
          <TextBlock Text="{Binding DiskAvailable}" Classes="mono" />
        </StackPanel>

        <Button Grid.Column="4"
                Classes="ghost"
                Content="Customise…"
                VerticalAlignment="Center"
                Click="OnToggleCustomize" />

      </Grid>
    </Border>

  </Grid>

</UserControl>
